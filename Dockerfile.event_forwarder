FROM python:3.12-slim AS builder

WORKDIR /app
COPY pyproject.toml ./

RUN apt-get update && apt-get install -y --no-install-recommends gcc && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir --prefix=/install ".[event-forwarder]"

FROM python:3.12-slim

WORKDIR /app
COPY --from=builder /install /usr/local
COPY chris_streaming/ chris_streaming/

CMD ["python", "-m", "chris_streaming.event_forwarder"]
