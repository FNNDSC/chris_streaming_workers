# ============================================================================
# ChRIS Streaming Workers — Environment Variables
# ============================================================================

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN

# SASL/PLAIN user passwords (must match kafka_server_jaas.conf)
EVENT_FORWARDER_PASSWORD=event-forwarder-secret
LOG_PRODUCER_PASSWORD=log-producer-secret
STATUS_CONSUMER_PASSWORD=status-consumer-secret
LOG_CONSUMER_PASSWORD=log-consumer-secret

# Kafka admin (for init script and broker)
KAFKA_ADMIN_PASSWORD=admin-secret

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL (status consumer DB) ---
POSTGRES_DB=chris_streaming
POSTGRES_USER=chris
POSTGRES_PASSWORD=chris1234
DB_DSN=postgresql://chris:chris1234@postgres:5432/chris_streaming

# --- OpenSearch ---
OPENSEARCH_URL=http://opensearch:9200

# --- pfcon ---
PFCON_USER=pfcon
PFCON_PASSWORD=pfcon1234
PFCON_SECRET_KEY=dev-secret-key

# --- Docker socket (for event forwarder and fluent-bit) ---
DOCKER_SOCK=/var/run/docker.sock

# --- UID/GID for pfcon containers ---
UID=1000
GID=1000
