# ============================================================================
# ChRIS Streaming Workers — Environment Variables
# ============================================================================

# --- Redis (Streams + Pub/Sub + Celery broker) ---
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL (celery worker DB) ---
POSTGRES_DB=chris_streaming
POSTGRES_USER=chris
POSTGRES_PASSWORD=chris1234
DB_DSN=postgresql://chris:chris1234@postgres:5432/chris_streaming

# --- OpenSearch ---
OPENSEARCH_URL=http://opensearch:9200

# --- pfcon ---
PFCON_USER=pfcon
PFCON_PASSWORD=pfcon1234
PFCON_SECRET_KEY=dev-secret-key

# --- Docker socket (event forwarder + log forwarder) ---
DOCKER_SOCK=/var/run/docker.sock

# --- UID/GID for pfcon containers ---
UID=1000
GID=1000
