{
  "index_patterns": ["job-logs-*"],
  "template": {
    "settings": {
      "number_of_shards": 2,
      "number_of_replicas": 0,
      "refresh_interval": "5s",
      "index.mapping.total_fields.limit": 200
    },
    "mappings": {
      "properties": {
        "event_id": {
          "type": "keyword"
        },
        "job_id": {
          "type": "keyword"
        },
        "job_type": {
          "type": "keyword"
        },
        "container_name": {
          "type": "keyword"
        },
        "line": {
          "type": "text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "ignore_above": 2048
            }
          }
        },
        "stream": {
          "type": "keyword"
        },
        "timestamp": {
          "type": "date"
        }
      }
    }
  },
  "priority": 100
}
